{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".tmp/quick-checks",
    "rootDir": ".",
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "scripts/reports/quick_banzuke_checks.ts",
    "scripts/reports/quick_torikumi_checks.ts",
    "scripts/reports/lower_division_banzuke_movement.ts",
    "src/logic/**/*.ts"
  ]
}
